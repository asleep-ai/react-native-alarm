# Exclude all top-level hidden directories by convention
/.*/

# Exclude tarballs generated by `npm pack`
/*.tgz

# Source files (only build output should be published)
/src/
/tsconfig.json

# Test files
__mocks__
__tests__

# Build artifacts
/android/build/
/android/.gradle/
/android/local.properties

# Development files
/babel.config.js
/example/
/node_modules/
*.log
*.tgz

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
