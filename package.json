{
  "name": "@asleep-ai/react-native-alarm",
  "version": "0.1.3",
  "description": "Asleep React Native Alarm using iOS AlarmKit (iOS 26+)",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "source": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf build",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asleep-ai/react-native-alarm.git"
  },
  "author": "Qube <qube@asleep.ai> (https://github.com/Sun-Woo-Kim)",
  "license": "MIT",
  "homepage": "https://github.com/asleep-ai/react-native-alarm#readme",
  "files": [
    "build",
    "ios",
    "android",
    "expo-module.config.json",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.74",
    "expo": ">=51"
  },
  "dependencies": {
    "expo-modules-core": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/react-native": "^0.73.0",
    "rimraf": "^6.0.1"
  }
}
